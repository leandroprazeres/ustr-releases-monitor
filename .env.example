# =========================================================================
# CONFIGURAÇÕES DO MONITOR DE RELEASES DO USTR
# =========================================================================

# URL do USTR a ser monitorada
TARGET_URL=https://ustr.gov/about-us/policy-offices/press-office/press-releases

# Arquivo onde o estado do último release é salvo
STATE_FILE=state.json

# Intervalo em segundos para verificação contínua (se rodar com --loop)
LOOP_INTERVAL_SECONDS=60

# =========================================================================
# CONFIGURAÇÕES DE E-MAIL (SMTP)
# =========================================================================
EMAIL_SENDER=seu_email@gmail.com
EMAIL_PASSWORD=sua_senha_de_aplicativo_gmail
EMAIL_RECEIVER=email_destinatario@gmail.com
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465

# =========================================================================
# CONFIGURAÇÕES DE WHATSAPP
# Opções para WHATSAPP_PROVIDER: 'callmebot', 'twilio' ou 'none'
# =========================================================================
WHATSAPP_PROVIDER=none

# Configurações para CallMeBot (Gratuito)
# Registre-se enviando mensagem pelo WhatsApp e receba a API key
CALLMEBOT_PHONE=+5511999999999
CALLMEBOT_API_KEY=sua_chave_aqui

# Configurações para Twilio (Oficial / Pago)
TWILIO_ACCOUNT_SID=ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
TWILIO_AUTH_TOKEN=sua_token_aqui
TWILIO_FROM_WHATSAPP=whatsapp:+14155238886
TWILIO_TO_WHATSAPP=whatsapp:+5511999999999

# =========================================================================
# CONFIGURAÇÕES DE PUSH NOTIFICATIONS
# Opções para PUSH_PROVIDER: 'telegram', 'pushover', 'pushbullet' ou 'none'
# =========================================================================
PUSH_PROVIDER=none

# Configurações para Telegram Bot (Gratuito)
# Crie um bot via @BotFather e use @userinfobot para descobrir seu Chat ID
TELEGRAM_BOT_TOKEN=123456789:ABCdefGhIJKlmNoPQRsTUVwxyZ
TELEGRAM_CHAT_ID=seu_chat_id_aqui

# Configurações para Pushover
PUSHOVER_USER_KEY=user_key_aqui
PUSHOVER_API_TOKEN=api_token_aqui

# Configurações para Pushbullet
PUSHBULLET_ACCESS_TOKEN=access_token_aqui
